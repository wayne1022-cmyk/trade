# ============================================================
# Alpha Vantage - USDJPY 分鐘 K 線資料源
# 申請網址：https://www.alphavantage.co/support/#api-key
# ============================================================
ALPHA_VANTAGE_KEY=YOUR_ALPHA_VANTAGE_KEY_HERE

# ============================================================
# Finnhub - 外匯新聞資料源
# 申請網址：https://finnhub.io/dashboard
# ============================================================
FINNHUB_KEY=YOUR_FINNHUB_KEY_HERE

# ============================================================
# Google Gemini - AI 決策大腦
# 申請網址：https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ============================================================
# IG Trading - 交易執行層（初期使用 Demo 環境）
# 申請網址：https://labs.ig.com/gettingstarted
# ============================================================
IG_API_KEY=YOUR_IG_API_KEY_HERE
IG_IDENTIFIER=YOUR_IG_ACCOUNT_EMAIL_HERE
IG_PASSWORD=YOUR_IG_ACCOUNT_PASSWORD_HERE

# Demo 環境固定網址，上線時再替換為正式環境
IG_API_URL=https://demo-api.ig.com/gateway/deal